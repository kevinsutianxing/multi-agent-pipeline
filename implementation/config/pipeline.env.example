# Controller host (SZ81)
PIPELINE_ROOT=/home/ubuntu/multi-agent-pipeline/implementation
PIPELINE_DB=/home/ubuntu/multi-agent-pipeline/implementation/state/pipeline.db
PIPELINE_RUNS_DIR=/home/ubuntu/multi-agent-pipeline/implementation/state/runs
PIPELINE_MAX_ATTEMPTS=3
PIPELINE_LEASE_SECONDS=1200
PIPELINE_HEARTBEAT_SECONDS=30
PIPELINE_AGENT_TIMEOUT_SECONDS=900
PIPELINE_NOTIFY_TIMEOUT_SECONDS=60

# Agent adapters as shell-like argv strings. Override hosts/paths as needed.
PIPELINE_CODEX_CMD="ssh hk43 codex exec --ephemeral --sandbox read-only -"
PIPELINE_CLAUDE_CMD="claude --safe-mode --print --output-format text --permission-mode plan"
PIPELINE_HERMESCOLD_CMD="ssh hk43 /home/ubuntu/.local/bin/hermescold-pipeline-worker.py"
PIPELINE_NOTIFY_CMD="ssh hk43 /home/ubuntu/.local/bin/hermeskevin-pipeline-notify.py"
