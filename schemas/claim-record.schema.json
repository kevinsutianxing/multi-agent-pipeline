{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/claim-record.schema.json",
  "title": "Financial Research Claim Record",
  "type": "object",
  "additionalProperties": true,
  "required": ["claim_id", "text", "classification", "material", "status"],
  "properties": {
    "claim_id": {"type": "string", "minLength": 1},
    "text": {"type": "string", "minLength": 1},
    "classification": {
      "type": "string",
      "enum": ["FACT", "CALCULATION", "INFERENCE", "HYPOTHESIS", "SCENARIO"]
    },
    "material": {"type": "boolean"},
    "evidence_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "calculation_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "as_of": {"type": ["string", "null"], "format": "date"},
    "confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "contradiction_status": {
      "type": "string",
      "enum": ["NONE", "DISCLOSED", "UNRESOLVED"]
    },
    "status": {
      "type": "string",
      "enum": ["VERIFIED", "PARTIAL", "CONFLICTED", "NOT_VERIFIED"]
    },
    "owner": {"type": ["string", "null"]},
    "review_status": {
      "type": ["string", "null"],
      "enum": ["PASS", "FAIL", "PENDING", null]
    }
  }
}
