{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/finance-data-snapshot.schema.json",
  "title": "Financial Data MCP Snapshot Result",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "status",
    "source_id",
    "evidence_id",
    "dataset_id",
    "provider",
    "query_parameters",
    "retrieved_at",
    "as_of",
    "snapshot_path",
    "content_sha256",
    "validation_status"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["OK", "PARTIAL", "NOT_FOUND", "CONFLICTED", "ERROR"]
    },
    "source_id": {"type": "string", "minLength": 1},
    "evidence_id": {"type": "string", "minLength": 1},
    "dataset_id": {"type": "string", "minLength": 1},
    "provider": {"type": "string", "minLength": 1},
    "source_locator": {"type": ["string", "null"]},
    "query_parameters": {"type": "object"},
    "retrieved_at": {"type": "string", "format": "date-time"},
    "as_of": {"type": "string", "format": "date"},
    "observation_start": {"type": ["string", "null"], "format": "date"},
    "observation_end": {"type": ["string", "null"], "format": "date"},
    "published_at": {"type": ["string", "null"], "format": "date-time"},
    "available_at": {"type": ["string", "null"], "format": "date-time"},
    "available_at_rule": {"type": ["string", "null"]},
    "snapshot_path": {"type": "string", "minLength": 1},
    "content_sha256": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"},
    "row_count": {"type": ["integer", "null"], "minimum": 0},
    "schema_fingerprint": {"type": ["string", "null"]},
    "entity_ids": {"type": "array", "items": {"type": "string"}},
    "fields": {"type": "array", "items": {"type": "string"}},
    "unit": {"type": ["string", "null"]},
    "currency": {"type": ["string", "null"]},
    "timezone": {"type": ["string", "null"]},
    "frequency": {"type": ["string", "null"]},
    "adjustment": {"type": ["string", "null"]},
    "revision_policy": {"type": ["string", "null"]},
    "license_or_usage_note": {"type": ["string", "null"]},
    "limitations": {"type": "array", "items": {"type": "string"}},
    "validation_status": {
      "type": "string",
      "enum": ["PENDING", "VALIDATED", "FAILED", "WAIVED"]
    }
  }
}
